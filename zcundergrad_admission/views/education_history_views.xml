<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List view --> 
    <record id="view_education_history_tree" model="ir.ui.view">
        <field name="name">education.history.tree</field>
        <field name="model">education.history</field>
        <field name="type">list</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <list string="Education History">
                <field name="applicant_id"/>
                <field name="institution_name"/>
                <field name="qualification"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="grade"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_education_history_form" model="ir.ui.view">
        <field name="name">education.history.form</field>
        <field name="model">education.history</field>
        <field name="type">form</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <form string="Education History">
                <sheet>
                    <group>
                        <field name="applicant_id" options="{'no_open': True}"/>
                        <field name="institution_name"/>
                        <field name="qualification"/>
                    </group>

                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="grade"/>
                    </group>

                    <group>
                        <field name="document" filename="institution_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_education_history_search" model="ir.ui.view">
        <field name="name">education.history.search</field>
        <field name="model">education.history</field>
        <field name="type">search</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <search string="Search Education History">
                <field name="institution_name"/>
                <field name="qualification"/>
                <field name="applicant_id"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_education_history" model="ir.actions.act_window">
        <field name="name">Education History</field>
        <field name="res_model">education.history</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No education history records found.
            </p>
        </field>
    </record>

    <menuitem id="menu_education_history"
              name="Education History"
              parent="menu_admission_root"
              action="action_education_history"
              sequence="10"/>
              
