<odoo>

<record id="rule_portal_admission_applicant_own" model="ir.rule">
<field name="name">Admission Applicant - portal own</field>
<field name="model_id" ref="model_admission_applicant"/>
<field name="groups" eval="[(4, ref('base.group_portal'))]"/>

<field name="domain_force">[('user_id', '=', user.id)]</field>
<field name="perm_read" eval="1"/>
<field name="perm_write" eval="1"/>
<field name="perm_create" eval="1"/>
<field name="perm_unlink" eval="0"/>
</record>

<record id="rule_portal_education_history_own" model="ir.rule">
<field name="name">Education History - portal own</field>
<field name="model_id" ref="model_education_history"/>
<field name="groups" eval="[(4, ref('base.group_portal'))]"/>
<field name="domain_force"> [('applicant_id.user_id', '=', user.id)] </field>
<field name="perm_read" eval="1"/>
<field name="perm_write" eval="1"/>
<field name="perm_create" eval="1"/>
<field name="perm_unlink" eval="0"/>
</record>
</odoo>
